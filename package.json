{
  "name": "devtodo",
  "version": "0.1.0",
  "description": "Cross-repo TODO manager for developers using markdown files",
  "type": "module",
  "bin": {
    "devtodo": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "todo",
    "cli",
    "mcp",
    "developer-tools",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/baekho-lim/devtodo.git"
  },
  "homepage": "https://github.com/baekho-lim/devtodo#readme",
  "bugs": {
    "url": "https://github.com/baekho-lim/devtodo/issues"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.27.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
